<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ReihenNav" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#E0B34A</item>
        <item name="colorSecondary">#39D3E0</item>
        <item name="android:windowBackground">#12161C</item>
        <item name="android:statusBarColor">#12161C</item>
    </style>

    <style name="Stat">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#39D3E0</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Tool">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">2dp</item>
        <item name="android:textSize">11sp</item>
        <item name="android:padding">4dp</item>
        <item name="android:minWidth">0dp</item>
    </style>
</resources>
